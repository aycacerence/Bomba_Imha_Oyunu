<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_dark"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingLeft="22dp"
        android:paddingTop="52dp"
        android:paddingRight="22dp"
        android:paddingBottom="22dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Bomba Uzmanı Rehberi"
            android:textColor="@color/text_main"
            android:textSize="30sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:lineSpacingExtra="4dp"
            android:text="Bombayı görmeden, imhacının tarif ettiği bilgilere göre doğru talimatı ver."
            android:textColor="@color/text_soft"
            android:textSize="15sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:fontFamily="monospace"
            android:text="TEKNİK DOKÜMANLAR"
            android:textColor="@color/neon_green"
            android:textSize="13sp"
            android:textStyle="bold" />

        <LinearLayout
            android:id="@+id/cardWireGuide"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/module_unsolved"
            android:clickable="true"
            android:focusable="true"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Kablolar Hakkında"
                android:textColor="@color/neon_yellow"
                android:textSize="19sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Kablo sayısı ve renk sırasına göre hangi kablonun kesileceğini belirle."
                android:textColor="@color/text_soft"
                android:textSize="14sp" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/cardButtonGuide"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_panel"
            android:clickable="true"
            android:focusable="true"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Büyük Düğme Hakkında"
                android:textColor="@color/neon_green"
                android:textSize="19sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Düğme rengi, yazısı, pil sayısı ve indicator bilgisine göre doğru işlemi seç."
                android:textColor="@color/text_soft"
                android:textSize="14sp" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/cardColorMemoryGuide"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_panel"
            android:clickable="true"
            android:focusable="true"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Renk Hafıza Hakkında"
                android:textColor="@color/neon_yellow"
                android:textSize="19sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Yanan renge, hata sayısına ve seri numarasına göre basılacak rengi bul."
                android:textColor="@color/text_soft"
                android:textSize="14sp" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/cardDialGuide"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_panel"
            android:clickable="true"
            android:focusable="true"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Kadran Modülü Hakkında"
                android:textColor="@color/neon_yellow"
                android:textSize="19sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Seri numarası, pil sayısı ve indicator bilgisine göre yön sırasını belirle."
                android:textColor="@color/text_soft"
                android:textSize="14sp" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/cardPasswordGuide"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_panel"
            android:clickable="true"
            android:focusable="true"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Şifre Paneli Hakkında"
                android:textColor="@color/neon_green"
                android:textSize="19sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Seri numarası, pil sayısı, indicator ve güvenlik kelimesine göre PIN hesapla."
                android:textColor="@color/text_soft"
                android:textSize="14sp" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/cardBackToRoles"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:background="@drawable/btn_neon_red"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical"
            android:minHeight="52dp"
            android:padding="14dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="Rol Seçimine Dön"
                android:textColor="@color/text_main"
                android:textSize="15sp"
                android:textStyle="bold" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>
