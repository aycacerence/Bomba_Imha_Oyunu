<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_dark"
    android:orientation="vertical"
    android:padding="22dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="Skor Geçmişi"
        android:textColor="@color/text_main"
        android:textSize="30sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:text="Önceki görev raporları"
        android:textColor="@color/text_soft"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/txtEmptyScores"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:background="@drawable/bg_panel"
        android:gravity="center"
        android:text="Henüz skor kaydı yok."
        android:textColor="@color/text_soft"
        android:textSize="16sp"
        android:visibility="gone" />

    <ListView
        android:id="@+id/listScores"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="20dp"
        android:layout_weight="1"
        android:cacheColorHint="@android:color/transparent"
        android:divider="@android:color/transparent"
        android:dividerHeight="10dp" />

    <Button
        android:id="@+id/btnClearScores"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:background="@drawable/btn_neon_red"
        android:minHeight="52dp"
        android:text="Geçmişi Temizle"
        android:textAllCaps="false"
        android:textColor="@color/text_main"
        android:textStyle="bold" />

    <Button
        android:id="@+id/btnScoreMainMenu"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:background="@drawable/btn_neon_green"
        android:minHeight="52dp"
        android:text="Ana Menü"
        android:textAllCaps="false"
        android:textColor="@color/text_main"
        android:textStyle="bold" />

</LinearLayout>
