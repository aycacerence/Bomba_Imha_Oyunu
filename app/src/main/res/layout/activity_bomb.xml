<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_dark"
    android:fitsSystemWindows="true">

    <ScrollView
        android:id="@+id/bombScrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:fadeScrollbars="false"
        android:fillViewport="true"
        android:overScrollMode="ifContentScrolls"
        android:scrollbars="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingLeft="20dp"
            android:paddingTop="20dp"
            android:paddingRight="20dp"
            android:paddingBottom="96dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:gravity="center"
                android:text="BOMBA KONTROL PANELİ"
                android:textColor="@color/neon_yellow"
                android:textSize="15sp"
                android:textStyle="bold" />

        <com.example.codedefuse.SevenSegmentTimerView
            android:id="@+id/txtTimer"
            android:layout_width="match_parent"
            android:layout_height="122dp"
            android:layout_marginTop="12dp" />

        <Button
            android:id="@+id/btnExitBomb"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/btn_neon_red"
            android:minHeight="48dp"
            android:text="Oyundan Çık"
            android:textAllCaps="false"
            android:textColor="@color/text_main"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_panel"
            android:orientation="vertical">

            <TextView
                android:id="@+id/txtMistakes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:text="Hata 0/3"
                android:textColor="@color/neon_red"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtSolvedCount"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:fontFamily="monospace"
                android:text="Çözülen Modül: 0/5"
                android:textColor="@color/text_soft"
                android:textSize="14sp" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_panel"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:text="BOMBA BİLGİLERİ"
                android:textColor="@color/neon_green"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtSerialNumber"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:fontFamily="monospace"
                android:text="Seri No: -----"
                android:textColor="@color/text_main"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/txtBatteryCount"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:fontFamily="monospace"
                android:text="Pil Sayısı: 0"
                android:textColor="@color/text_main"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/txtIndicatorCode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:fontFamily="monospace"
                android:text="Indicator: ---"
                android:textColor="@color/text_main"
                android:textSize="15sp" />

        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:fontFamily="monospace"
            android:text="AKTİF MODÜLLER"
            android:textColor="@color/neon_yellow"
            android:textSize="14sp"
            android:textStyle="bold" />

        <!-- Module Cards -->
        <LinearLayout
            android:id="@+id/cardWireModule"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/module_unsolved"
            android:clickable="true"
            android:focusable="true"
            android:orientation="vertical">
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Kablo Modülü"
                android:textColor="@color/text_main"
                android:textSize="18sp"
                android:textStyle="bold" />
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:text="Doğru kabloyu kes ve devreyi güvenli hale getir."
                android:textColor="@color/text_soft"
                android:textSize="14sp" />
            <TextView
                android:id="@+id/txtWireStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:fontFamily="monospace"
                android:text="AKTİF"
                android:textColor="@color/neon_yellow"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/cardButtonModule"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/module_unsolved"
            android:clickable="true"
            android:focusable="true"
            android:orientation="vertical">
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Büyük Düğme"
                android:textColor="@color/text_main"
                android:textSize="18sp"
                android:textStyle="bold" />
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:text="Düğmenin rengine ve yazısına göre doğru hamleyi yap."
                android:textColor="@color/text_soft"
                android:textSize="14sp" />
            <TextView
                android:id="@+id/txtButtonStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:fontFamily="monospace"
                android:text="AKTİF"
                android:textColor="@color/neon_yellow"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/cardColorMemoryModule"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/module_unsolved"
            android:clickable="true"
            android:focusable="true"
            android:orientation="vertical">
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Renk Hafıza"
                android:textColor="@color/text_main"
                android:textSize="18sp"
                android:textStyle="bold" />
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:text="Gösterilen renk sırasını takip et ve aynı sırayı gir."
                android:textColor="@color/text_soft"
                android:textSize="14sp" />
            <TextView
                android:id="@+id/txtColorMemoryStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:fontFamily="monospace"
                android:text="AKTİF"
                android:textColor="@color/neon_yellow"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/cardDialModule"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/module_unsolved"
            android:clickable="true"
            android:focusable="true"
            android:orientation="vertical">
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Kadran Modülü"
                android:textColor="@color/text_main"
                android:textSize="18sp"
                android:textStyle="bold" />
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:text="Kadranı doğru yön sırasına getir."
                android:textColor="@color/text_soft"
                android:textSize="14sp" />
            <TextView
                android:id="@+id/txtDialStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:fontFamily="monospace"
                android:text="AKTİF"
                android:textColor="@color/neon_yellow"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/cardPasswordModule"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/module_unsolved"
            android:clickable="true"
            android:focusable="true"
            android:orientation="vertical">
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Şifre Paneli"
                android:textColor="@color/text_main"
                android:textSize="18sp"
                android:textStyle="bold" />
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:text="Doğru kelimeyi bul ve panel kilidini aç."
                android:textColor="@color/text_soft"
                android:textSize="14sp" />
            <TextView
                android:id="@+id/txtPasswordStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:fontFamily="monospace"
                android:text="AKTİF"
                android:textColor="@color/neon_yellow"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <View
        android:id="@+id/redWarningOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:alpha="0"
        android:background="#AAFF0000"
        android:clickable="false"
        android:visibility="gone" />

    <FrameLayout
        android:id="@+id/explosionOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/bg_dark"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone">

        <ImageView
            android:id="@+id/imgExplosion"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:adjustViewBounds="true"
            android:contentDescription="Bomba patlaması"
            android:padding="18dp"
            android:scaleType="fitCenter"
            android:src="@drawable/bomb_explosion" />

    </FrameLayout>
</FrameLayout>
