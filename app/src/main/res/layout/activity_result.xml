<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_dark"
    android:clipToPadding="false"
    android:fadeScrollbars="false"
    android:fillViewport="true"
    android:fitsSystemWindows="true"
    android:overScrollMode="ifContentScrolls"
    android:scrollbars="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingLeft="24dp"
        android:paddingTop="24dp"
        android:paddingRight="24dp"
        android:paddingBottom="104dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:gravity="center"
            android:text="GÖREV SONUCU"
            android:textColor="@color/neon_yellow"
            android:textSize="14sp"
            android:textStyle="bold" />

        <LinearLayout
            android:id="@+id/resultBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:gravity="center"
            android:minHeight="132dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/txtResultTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="Bomba Etkisiz Hale Getirildi"
                android:textColor="@color/neon_green"
                android:textSize="28sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtResultMessage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:gravity="center"
                android:lineSpacingExtra="4dp"
                android:text="Tüm modüller başarıyla çözüldü."
                android:textColor="@color/text_soft"
                android:textSize="15sp" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:background="@drawable/bg_panel"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:text="GÖREV RAPORU"
                android:textColor="@color/neon_yellow"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtResultTime"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:fontFamily="monospace"
                android:text="Kalan Süre: 00:00"
                android:textColor="@color/text_main"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/txtResultMistakes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:fontFamily="monospace"
                android:text="Hata Sayısı: 0/3"
                android:textColor="@color/text_main"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/txtResultSolved"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:fontFamily="monospace"
                android:text="Çözülen Modül: 0/5"
                android:textColor="@color/text_main"
                android:textSize="15sp" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:background="@drawable/bg_panel"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:gravity="center"
                android:text="FİNAL SKOR"
                android:textColor="@color/text_soft"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtResultScore"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:fontFamily="monospace"
                android:gravity="center"
                android:text="0"
                android:textColor="@color/neon_green"
                android:textSize="42sp"
                android:textStyle="bold" />

        </LinearLayout>

        <Button
            android:id="@+id/btnMainMenu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:background="@drawable/btn_neon_green"
            android:minHeight="52dp"
            android:text="Ana Menü"
            android:textAllCaps="false"
            android:textColor="@color/text_main"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnPlayAgain"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
        android:background="@drawable/btn_neon_yellow"
        android:minHeight="52dp"
        android:text="Tekrar Oyna"
        android:textAllCaps="false"
        android:textColor="@color/text_dark"
        android:textStyle="bold" />

        <Button
            android:id="@+id/btnResultScoreHistory"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/btn_neon_red"
            android:minHeight="52dp"
            android:text="Skor Geçmişi"
            android:textAllCaps="false"
            android:textColor="@color/text_main"
            android:textStyle="bold" />

    </LinearLayout>
</ScrollView>
