<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_dark"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="22dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Şifre Paneli Hakkında"
            android:textColor="@color/text_main"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:lineSpacingExtra="4dp"
            android:text="İmhacı seri numarasını, pil sayısını, indicator kodunu ve güvenlik kelimesini söylemelidir."
            android:textColor="@color/text_soft"
            android:textSize="15sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:background="@drawable/bg_panel"
            android:fontFamily="monospace"
            android:lineSpacingExtra="5dp"
            android:text="PIN HESAPLAMA&#10;&#10;1. Seri numarasındaki ilk rakamı al.&#10;2. Pil sayısı 2 veya daha fazlaysa bu rakama 3 ekle.&#10;3. Indicator CAR ise sonuca 2 ekle.&#10;4. Güvenlik kelimesi 5 harfliyse sonuca 5 ekle.&#10;5. Güvenlik kelimesi sesli harfle başlıyorsa sonuca 2 ekle.&#10;6. Güvenlik kelimesi R harfi içeriyorsa sonucu 2 ile çarp.&#10;7. Sonuç 2 basamaklı değilse başına 0 ekle."
            android:textColor="@color/text_soft"
            android:textSize="14sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_panel"
            android:fontFamily="monospace"
            android:lineSpacingExtra="5dp"
            android:text="ÖRNEK ÇÖZÜM&#10;&#10;Seri No: A7K4B&#10;Pil: 2&#10;Indicator: CAR&#10;Güvenlik Kelimesi: ORBIT&#10;&#10;İlk rakam: 7&#10;7 + 3 = 10&#10;10 + 2 = 12&#10;Kelime 5 harfli: 12 + 5 = 17&#10;Sesli harfle başlıyor: 17 + 2 = 19&#10;R içeriyor: 19 x 2 = 38&#10;PIN = 38"
            android:textColor="@color/text_soft"
            android:textSize="14sp" />

        <Button
            android:id="@+id/btnBackFromPasswordGuide"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:background="@drawable/btn_neon_green"
            android:text="Ana Rehber Menüsüne Dön"
            android:textAllCaps="false"
            android:textColor="@color/text_main"
            android:textStyle="bold" />

    </LinearLayout>
</ScrollView>
