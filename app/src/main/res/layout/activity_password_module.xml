<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_dark"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="22dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="Şifre Paneli"
            android:textColor="@color/text_main"
            android:textSize="28sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_panel"
            android:orientation="vertical">

            <TextView
                android:id="@+id/txtPasswordSerial"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:text="Seri No: A7K4B"
                android:textColor="@color/neon_green"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtPasswordBattery"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:fontFamily="monospace"
                android:text="Pil Sayısı: 2"
                android:textColor="@color/neon_yellow"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtPasswordIndicator"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:fontFamily="monospace"
                android:text="Indicator: CAR"
                android:textColor="@color/text_soft"
                android:textSize="15sp" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:background="@drawable/module_unsolved"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:gravity="center"
                android:text="GÜVENLİK KELİMESİ"
                android:textColor="@color/neon_yellow"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtPasswordWord"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:fontFamily="monospace"
                android:gravity="center"
                android:text="Yükleniyor..."
                android:textColor="@color/neon_green"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtPasswordWordSource"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:text="Güvenlik kelimesi alınıyor."
                android:textColor="@color/text_soft"
                android:textSize="13sp" />

        </LinearLayout>

        <EditText
            android:id="@+id/editPin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:background="@drawable/input_background"
            android:fontFamily="monospace"
            android:gravity="center"
            android:hint="PIN"
            android:inputType="number"
            android:maxLines="1"
            android:padding="12dp"
            android:textColor="@color/text_main"
            android:textColorHint="@color/text_muted"
            android:textSize="18sp" />

        <Button
            android:id="@+id/btnCheckPin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/btn_neon_green"
            android:text="PIN Kontrol Et"
            android:textAllCaps="false"
            android:textColor="@color/text_main"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnBackFromPassword"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/btn_neon_red"
            android:text="Bombaya Dön"
            android:textAllCaps="false"
            android:textColor="@color/text_main"
            android:textStyle="bold" />

    </LinearLayout>
</ScrollView>
